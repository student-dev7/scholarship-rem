# コピーして .env.local を作成（ローカルは .env.local を推奨。Next.js は .env も併用可）
# 本番の公開 URL（sitemap.xml 用。末尾スラッシュなし）
# NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Firebase (client)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# FCM (server) — サーバーのみ（service account JSON を1行で）
FIREBASE_SERVICE_ACCOUNT_JSON=

# Cron / 手動プッシュ API（GET・POST /api/send-push の Bearer）
ADMIN_API_SECRET=change-me
# Vercel Cron が GET /api/send-push に付ける Bearer は CRON_SECRET。ADMIN_API_SECRET と同じ値にすること。
# VERCEL でのみ必要: CRON_SECRET=

# PWA アイコン: public/icons/custom/ に icon-192x192.png & icon-512x512.png
# または source.png（512px 以上の正方形）を置いて npm run icons:apply

# 監視スクリプト (CI)
DISCORD_WEBHOOK_URL=
